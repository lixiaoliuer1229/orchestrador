# Production deployments should inject these values as environment variables.
# For local development only, copy this file to .env and replace the placeholders.
APP_ENV=production

ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here
ANTHROPIC_MODEL=claude-sonnet-4-6
# Leave empty to use Anthropic's official endpoint.
ANTHROPIC_BASE_URL=

# Optional: frontend static-resource directory used for generated charts.
# Defaults to ./langgraph_dataanalysis/public.
PUBLIC_DIR=

TAVILY_API_KEY=tvly-your-tavily-key-here
